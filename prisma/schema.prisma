generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanType {
  FREE
  ESSENTIAL
  PREMIUM
}

/// User is intentionally shaped to become the parent side of future
/// transaction relationships without introducing a placeholder model yet.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String?  @unique
  password  String
  planType  PlanType @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
